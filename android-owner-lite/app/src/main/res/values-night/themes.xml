<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.UtsavOwnerLite" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryContainer">@color/brand_accent</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowBackground">@color/app_background</item>
    </style>

    <style name="Theme.UtsavOwnerLite.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/app_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_mark</item>
        <item name="postSplashScreenTheme">@style/Theme.UtsavOwnerLite</item>
    </style>
</resources>
